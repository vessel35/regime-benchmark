# Regime Benchmark — application env template
# 사용:
#   cp env.example .env       # DSN 의 비밀번호 등 채움
#   set -a; source .env; set +a
#
# .env 는 .gitignore 처리됨.
# 본 파일은 **application 런타임용**. DB 부트스트랩(1 회용)은 셸 inline 으로 전달
# 한다 — docs/design.md §13.8 참조. 부트스트랩 자격은 .env 에 두지 않는다.

# 상시 application DSN (regime_owner 로 regime_benchmark 접속)
REGIME_BENCHMARK_DB_URL=postgres://regime_owner@localhost:5432/regime_benchmark
